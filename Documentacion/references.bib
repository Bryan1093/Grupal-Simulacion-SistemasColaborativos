@article{Harmon2016,
	abstract = {In this paper, we predict the likelihood of a player making a shot in basketball from multiagent trajectories. Previous approaches to similar problems center on hand-crafting features to capture domain specific knowledge. Although intuitive, recent work in deep learning has shown this approach is prone to missing important predictive features. To circumvent this issue, we present a convolutional neural network (CNN) approach where we initially represent the multiagent behavior as an image. To encode the adversarial nature of basketball, we use a multi-channel image which we then feed into a CNN. Additionally, to capture the temporal aspect of the trajectories we use "fading." By using gradient ascent, we were able to discover what the CNN filters look for during training. Last, we find that a combined FNN+CNN is the best performing network with an error rate of 26{\%}.},
	archivePrefix = {arXiv},
	arxivId = {1609.04849},
	author = {Harmon, Mark and Lucey, Patrick and Klabjan, Diego},
	eprint = {1609.04849},
	file = {:C$\backslash$:/Users/felipe/Documents/DOCTORADO/SURVEY-REVIEW/small-groups/1609.04849.pdf:pdf},
	mendeley-groups = {Tabla},
	title = {{Predicting Shot Making in Basketball using Convolutional Neural Networks Learnt from Adversarial Multiagent Trajectories}},
	url = {http://arxiv.org/abs/1609.04849},
	journal={arXiv preprint arXiv:1609.04849},
	year = {2016}
}


